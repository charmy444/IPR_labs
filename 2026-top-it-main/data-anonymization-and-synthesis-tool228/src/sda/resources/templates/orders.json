{
  "template_id": "orders",
  "title": "Заказы",
  "columns": [
    {"name": "order_id", "provider": "auto_increment"},
    {"name": "user_id", "provider": "context_ref", "ref": "user_id"},
    {"name": "product_id", "provider": "context_ref", "ref": "product_id"},
    {
      "name": "amount",
      "provider": "random_int", 
      "min": 1,
      "max": 20
    },
    {"name": "order_date", "provider": "date_time_between"},
    {
      "name": "currency", 
      "provider": "random_element", 
      "elements": ["RUB", "USD"]
    }
  ]
}
