# Telegram Bot Token
# Получите токен у @BotFather в Telegram
BOT_TOKEN=your_telegram_bot_token_here

# Database URL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/support_bot?sslmode=disable

# Server Port
SERVER_PORT=8080

# Server Host
SERVER_HOST=0.0.0.0

# Frontend API URL
NEXT_PUBLIC_API_URL=http://localhost:8080

# OpenTelemetry → Grafana Tempo (optional; omit for local run without tracing)
# In docker compose with observability stack use: http://tempo:4318
# OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318
# OTEL_SERVICE_NAME=telegram-support-backend
